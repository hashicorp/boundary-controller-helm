{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "HashiCorp Boundary Controller Helm Chart Values Schema",
  "type": "object",
  "properties": {
    "nameOverride": {
      "type": "string"
    },
    "namespace": {
      "type": "string"
    },
    "image": {
      "type": "object",
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string"
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      },
      "additionalProperties": false
    },
    "imagePullSecrets": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["name"],
        "additionalProperties": false
      }
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "automountServiceAccountToken": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "podSecurityContext": {
      "type": "object"
    },
    "containerSecurityContext": {
      "type": "object"
    },
    "podAnnotations": {
      "type": "object"
    },
    "nodeSelector": {
      "type": "object"
    },
    "tolerations": {
      "type": "array"
    },
    "affinity": {
      "type": "object"
    },
    "podDisruptionBudget": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "minAvailable": {
          "oneOf": [
            { "type": "integer" },
            { "type": "string" }
          ]
        },
        "maxUnavailable": {
          "oneOf": [
            { "type": "integer" },
            { "type": "string" }
          ]
        }
      },
      "additionalProperties": true
    },
    "tls": {
      "type": "object",
      "properties": {
        "disabled": {
          "type": "boolean"
        },
        "secretName": {
          "type": "string"
        },
        "mountPath": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "secretRefs": {
      "type": "object",
      "properties": {
        "secretName": {
          "type": "string"
        },
        "validateExisting": {
          "type": "boolean"
        },
        "keys": {
          "type": "object",
          "properties": {
            "databaseUrl": { "type": "string" },
            "migrationUrl": { "type": "string" },
            "license": { "type": "string" },
            "adminUsername": { "type": "string" },
            "adminPassword": { "type": "string" },
            "kmsRoot": { "type": "string" },
            "kmsWorkerAuth": { "type": "string" },
            "kmsRecovery": { "type": "string" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "controller": {
      "type": "object",
      "properties": {
        "replicas": {
          "type": "integer",
          "minimum": 0
        },
        "rollingUpdate": {
          "type": "object",
          "properties": {
            "maxUnavailable": {},
            "maxSurge": {}
          },
          "additionalProperties": true
        },
        "livenessProbe": {
          "type": "object",
          "properties": {
            "scheme": {
              "type": "string",
              "enum": ["HTTP", "HTTPS"]
            }
          },
          "additionalProperties": true
        },
        "readinessProbe": {
          "type": "object",
          "properties": {
            "scheme": {
              "type": "string",
              "enum": ["HTTP", "HTTPS"]
            }
          },
          "additionalProperties": true
        },
        "resources": {
          "type": "object"
        },
        "service": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "database": {
      "type": "object",
      "properties": {
        "init": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            }
          },
          "additionalProperties": true
        },
        "migrate": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            }
          },
          "additionalProperties": true
        },
        "repair": {
          "type": "object",
          "properties": {
            "version": {
              "type": "string"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "bootstrapAdmin": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "runOnUpgrade": {
          "type": "boolean"
        },
        "waitTimeoutSeconds": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": true
    },
    "terminationGracePeriodSeconds": {
      "type": "integer",
      "minimum": 1
    }
  },
  "additionalProperties": true
}